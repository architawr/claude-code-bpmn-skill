    <bpmn:task id="Legacy" name="Legacy import"/>
    <bpmn:endEvent id="E" name="Done"/>
    <bpmn:sequenceFlow id="f1" sourceRef="S" targetRef="Triage"/>
    <bpmn:sequenceFlow id="f2" sourceRef="Triage" targetRef="Process"/>
    <bpmn:sequenceFlow id="f3" sourceRef="Triage" targetRef="Archive"/>
    <bpmn:sequenceFlow id="f4" sourceRef="Process" targetRef="E"/>
    <bpmn:sequenceFlow id="f5" sourceRef="Legacy" targetRef="E"/>
  </bpmn:process>
