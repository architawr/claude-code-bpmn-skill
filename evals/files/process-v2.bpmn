<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="D" targetNamespace="x">
  <bpmn:process id="Order" isExecutable="false">
    <bpmn:startEvent id="S" name="Order received"/>
    <bpmn:task id="Tcheck" name="Check stock"/>
    <bpmn:task id="Tcharge" name="Charge card"/>
    <bpmn:task id="Tship" name="Pack and ship"/>
    <bpmn:endEvent id="E" name="Shipped"/>
    <bpmn:sequenceFlow id="f1" sourceRef="S" targetRef="Tcheck"/>
    <bpmn:sequenceFlow id="f2" sourceRef="Tcheck" targetRef="Tcharge"/>
    <bpmn:sequenceFlow id="fnew" sourceRef="Tcharge" targetRef="Tship"/>
    <bpmn:sequenceFlow id="f4" sourceRef="Tship" targetRef="E"/>
  </bpmn:process>
</bpmn:definitions>
