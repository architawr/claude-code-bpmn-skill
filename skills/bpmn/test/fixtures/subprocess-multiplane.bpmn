<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Defs_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="P1" isExecutable="false">
    <bpmn:startEvent id="S1" name="Start">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="T1" name="Do thing">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:subProcess id="SP1" name="Packaging">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
      <bpmn:startEvent id="S2">
        <bpmn:outgoing>if1</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:task id="T2" name="Pack">
        <bpmn:incoming>if1</bpmn:incoming>
        <bpmn:outgoing>if2</bpmn:outgoing>
      </bpmn:task>
      <bpmn:endEvent id="E2">
        <bpmn:incoming>if2</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="if1" sourceRef="S2" targetRef="T2" />
      <bpmn:sequenceFlow id="if2" sourceRef="T2" targetRef="E2" />
    </bpmn:subProcess>
    <bpmn:endEvent id="E1" name="End">
      <bpmn:incoming>f3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="S1" targetRef="T1" />
    <bpmn:sequenceFlow id="f2" sourceRef="T1" targetRef="SP1" />
    <bpmn:sequenceFlow id="f3" sourceRef="SP1" targetRef="E1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_P1">
    <bpmndi:BPMNPlane id="BPMNPlane_P1" bpmnElement="P1">
      <bpmndi:BPMNShape id="S1_di" bpmnElement="S1">
        <dc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T1_di" bpmnElement="T1">
        <dc:Bounds x="175" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SP1_di" bpmnElement="SP1">
        <dc:Bounds x="325" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="E1_di" bpmnElement="E1">
        <dc:Bounds x="507" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1">
        <di:waypoint x="93" y="70" />
        <di:waypoint x="175" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2">
        <di:waypoint x="275" y="70" />
        <di:waypoint x="325" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f3_di" bpmnElement="f3">
        <di:waypoint x="425" y="70" />
        <di:waypoint x="507" y="70" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
  <bpmndi:BPMNDiagram id="BPMNDiagram_SP1">
    <bpmndi:BPMNPlane id="BPMNPlane_SP1" bpmnElement="SP1">
      <bpmndi:BPMNShape id="S2_di" bpmnElement="S2">
